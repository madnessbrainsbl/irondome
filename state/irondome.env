PROTECTED_USER="kali"
INTEGRATION_PROFILE="none"
ENABLE_LOCAL_HTTP_PROXY="yes"
INSTALL_PREFIX="/opt/irondome"
CLIPROXY_BIN="/opt/CLIProxyAPIPlus/cliproxy"
CLIPROXY_WORKDIR="/opt/CLIProxyAPIPlus"
CLIPROXY_AUTH_DIR="/var/lib/cliproxy/auth"
CLIPROXY_STORAGE_DIR="/var/lib/cliproxy"
ENABLE_STRICT="yes"
ENABLE_OPEN="yes"
ENABLE_GOOGLE_FORWARD="no"
ENABLE_BOOT_CLEANUP="yes"
INCLUDE_ROOT_WEB="yes"
TRANSPARENT_MTU="1200"
